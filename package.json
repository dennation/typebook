{
  "name": "@dennation/studio",
  "version": "0.1.0",
  "description": "React component preview tool with automatic variant generation from TypeScript types",
  "type": "module",
  "bin": {
    "studio": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "preview": "node ./dist/cli/index.js preview"
  },
  "dependencies": {
    "oxc-parser": "^0.60.0",
    "oxc-resolver": "^5.0.0",
    "vite": "^6.0.0",
    "express": "^4.21.0",
    "glob": "^11.0.0",
    "vscode-languageserver-protocol": "^3.17.0",
    "vscode-jsonrpc": "^8.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  }
}
