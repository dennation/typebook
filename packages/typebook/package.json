{
	"name": "@dennation/typebook",
	"version": "0.2.0",
	"description": "React component story tool with automatic variant generation from TypeScript types",
	"type": "module",
	"bin": {
		"typebook": "./dist/cli/index.mjs"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs"
		},
		"./react": {
			"types": "./dist/react/index.d.ts",
			"import": "./dist/react/index.mjs"
		},
		"./tanstack-router": {
			"types": "./dist/tanstack-router/index.d.ts",
			"import": "./dist/tanstack-router/index.mjs"
		},
		"./vite": {
			"types": "./dist/plugins/vite.d.ts",
			"import": "./dist/plugins/vite.mjs"
		},
		"./rollup": {
			"types": "./dist/plugins/rollup.d.ts",
			"import": "./dist/plugins/rollup.mjs"
		},
		"./rolldown": {
			"types": "./dist/plugins/rolldown.d.ts",
			"import": "./dist/plugins/rolldown.mjs"
		},
		"./webpack": {
			"types": "./dist/plugins/webpack.d.ts",
			"import": "./dist/plugins/webpack.mjs"
		},
		"./rspack": {
			"types": "./dist/plugins/rspack.d.ts",
			"import": "./dist/plugins/rspack.mjs"
		},
		"./esbuild": {
			"types": "./dist/plugins/esbuild.d.ts",
			"import": "./dist/plugins/esbuild.mjs"
		},
		"./farm": {
			"types": "./dist/plugins/farm.d.ts",
			"import": "./dist/plugins/farm.mjs"
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": [
		"**/*.css"
	],
	"scripts": {
		"build": "vite build",
		"dev": "vite build --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run"
	},
	"dependencies": {
		"oxc-parser": "^0.60.0",
		"shiki": "^3.23.0",
		"type-fest": "^5.6.0",
		"unplugin": "^3.0.0"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.1.18",
		"@tanstack/react-router": "^1.170.4",
		"@tanstack/router-core": "1.171.2",
		"@types/node": "^22.0.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"tailwindcss": "^4.1.18",
		"vite": "^6.0.0",
		"vite-plugin-dts": "^4.5.0",
		"vitest": "^4.0.18"
	},
	"peerDependencies": {
		"@tanstack/react-router": ">=1.168.0",
		"react": ">=18.0.0",
		"react-dom": ">=18.0.0",
		"typescript": ">=5.0.0"
	},
	"peerDependenciesMeta": {
		"@tanstack/react-router": {
			"optional": true
		},
		"typescript": {
			"optional": true
		}
	}
}