{
	"name": "@dennation/typebook",
	"version": "0.4.0",
	"description": "A toolkit for documenting React components from their TypeScript types — one bundler-plugin scan, plugins turn it into artifacts (AI-agent docs and more)",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/dennation/typebook.git",
		"directory": "packages/typebook"
	},
	"homepage": "https://github.com/dennation/typebook#readme",
	"bugs": "https://github.com/dennation/typebook/issues",
	"keywords": [
		"react",
		"typescript",
		"documentation",
		"components",
		"llms-txt",
		"unplugin",
		"ai-agents"
	],
	"type": "module",
	"bin": {
		"typebook": "./dist/cli/index.mjs"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs"
		},
		"./plugins/llm-instructions": {
			"types": "./dist/plugins/llm-instructions/index.d.ts",
			"import": "./dist/plugins/llm-instructions/index.mjs"
		},
		"./vite": {
			"types": "./dist/plugins/vite.d.ts",
			"import": "./dist/plugins/vite.mjs"
		},
		"./rollup": {
			"types": "./dist/plugins/rollup.d.ts",
			"import": "./dist/plugins/rollup.mjs"
		},
		"./rolldown": {
			"types": "./dist/plugins/rolldown.d.ts",
			"import": "./dist/plugins/rolldown.mjs"
		},
		"./webpack": {
			"types": "./dist/plugins/webpack.d.ts",
			"import": "./dist/plugins/webpack.mjs"
		},
		"./rspack": {
			"types": "./dist/plugins/rspack.d.ts",
			"import": "./dist/plugins/rspack.mjs"
		},
		"./esbuild": {
			"types": "./dist/plugins/esbuild.d.ts",
			"import": "./dist/plugins/esbuild.mjs"
		},
		"./farm": {
			"types": "./dist/plugins/farm.d.ts",
			"import": "./dist/plugins/farm.mjs"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "vite build",
		"dev": "vite build --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run"
	},
	"dependencies": {
		"tinyglobby": "^0.2.15",
		"unplugin": "^3.0.0"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"@types/react": "^19.0.0",
		"vite": "^6.0.0",
		"vite-plugin-dts": "^4.5.0",
		"vitest": "^4.0.18"
	},
	"peerDependencies": {
		"typescript": ">=5.0.0"
	},
	"peerDependenciesMeta": {
		"typescript": {
			"optional": true
		}
	}
}
