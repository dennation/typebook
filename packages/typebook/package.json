{
	"name": "@dennation/typebook",
	"version": "0.0.0",
	"description": "Scan React components' TypeScript prop types with a bundler plugin and generate documentation — AI-agent instructions and more, no codegen files",
	"license": "MIT",
	"type": "module",
	"bin": {
		"typebook": "./dist/cli/index.mjs"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs"
		},
		"./plugins/ai-instructions": {
			"types": "./dist/plugins/aiInstructions.d.ts",
			"import": "./dist/plugins/aiInstructions.mjs"
		},
		"./vite": {
			"types": "./dist/plugins/vite.d.ts",
			"import": "./dist/plugins/vite.mjs"
		},
		"./rollup": {
			"types": "./dist/plugins/rollup.d.ts",
			"import": "./dist/plugins/rollup.mjs"
		},
		"./rolldown": {
			"types": "./dist/plugins/rolldown.d.ts",
			"import": "./dist/plugins/rolldown.mjs"
		},
		"./webpack": {
			"types": "./dist/plugins/webpack.d.ts",
			"import": "./dist/plugins/webpack.mjs"
		},
		"./rspack": {
			"types": "./dist/plugins/rspack.d.ts",
			"import": "./dist/plugins/rspack.mjs"
		},
		"./esbuild": {
			"types": "./dist/plugins/esbuild.d.ts",
			"import": "./dist/plugins/esbuild.mjs"
		},
		"./farm": {
			"types": "./dist/plugins/farm.d.ts",
			"import": "./dist/plugins/farm.mjs"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "vite build",
		"dev": "vite build --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run"
	},
	"dependencies": {
		"unplugin": "^3.0.0"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"@types/react": "^19.0.0",
		"react": "^19.0.0",
		"vite": "^6.0.0",
		"vite-plugin-dts": "^4.5.0",
		"vitest": "^4.0.18"
	},
	"peerDependencies": {
		"typescript": ">=5.0.0"
	},
	"peerDependenciesMeta": {
		"typescript": {
			"optional": true
		}
	}
}
