{
	"name": "@dennation/typebook",
	"version": "0.2.0",
	"description": "React component story tool with automatic variant generation from TypeScript types",
	"type": "module",
	"bin": {
		"typebook": "./dist/cli/index.mjs"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs"
		},
		"./react": {
			"types": "./dist/react/index.d.ts",
			"import": "./dist/react/index.mjs"
		},
		"./vite": {
			"types": "./dist/plugins/vite/index.d.ts",
			"import": "./dist/plugins/vite.mjs"
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": [
		"**/*.css"
	],
	"scripts": {
		"build": "vite build",
		"dev": "vite build --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run"
	},
	"dependencies": {
		"oxc-parser": "^0.60.0",
		"shiki": "^3.23.0",
		"type-fest": "^5.6.0"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^22.0.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"tailwindcss": "^4.1.18",
		"vite-plugin-dts": "^4.5.0",
		"vitest": "^4.0.18"
	},
	"peerDependencies": {
		"react": ">=18.0.0",
		"react-dom": ">=18.0.0",
		"typescript": ">=5.0.0",
		"vite": ">=5.0.0"
	},
	"peerDependenciesMeta": {
		"typescript": {
			"optional": true
		},
		"vite": {
			"optional": true
		}
	}
}