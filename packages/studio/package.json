{
	"name": "@dennation/ui-studio",
	"version": "0.2.0",
	"description": "React component story tool with automatic variant generation from TypeScript types",
	"type": "module",
	"bin": {
		"ui-studio": "./dist/cli/index.js"
	},
	"exports": {
		".": {
			"types": "./dist/api/index.d.mts",
			"import": "./dist/api/index.mjs"
		},
		"./runtime": {
			"types": "./dist/runtime/index.d.mts",
			"import": "./dist/runtime/index.mjs"
		},
		"./react": {
			"types": "./dist/react/index.d.mts",
			"import": "./dist/react/index.mjs"
		},
		"./react/styles.css": "./dist/react/index.css",
		"./vite": {
			"types": "./dist/plugin/vite.d.mts",
			"import": "./dist/plugin/vite.mjs"
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": [
		"**/*.css"
	],
	"scripts": {
		"build": "pnpm run build:css && vite build",
		"build:css": "tailwindcss -i ./src/react/styles/styles.css -o ./src/react/styles/styles.generated.css --minify",
		"dev": "pnpm run build:css && vite build --watch",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@typescript/native-preview": "^7.0.0-dev.20260203.1",
		"glob": "^13.0.1",
		"oxc-parser": "^0.60.0",
		"picomatch": "^4.0.0"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"@types/picomatch": "^3.0.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"@tailwindcss/cli": "^4.1.18",
		"@tailwindcss/vite": "^4.1.18",
		"tailwindcss": "^4.1.18",
		"vite-plugin-dts": "^4.5.0",
		"typescript": "^5.7.0"
	},
	"peerDependencies": {
		"react": ">=18.0.0",
		"react-dom": ">=18.0.0",
		"vite": ">=5.0.0"
	}
}