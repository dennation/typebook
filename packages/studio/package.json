{
	"name": "@dennation/studio",
	"version": "0.2.0",
	"description": "React component story tool with automatic variant generation from TypeScript types",
	"type": "module",
	"bin": {
		"studio": "./dist/cli/index.js"
	},
	"exports": {
		".": {
			"types": "./dist/api/index.d.ts",
			"import": "./dist/api/index.js"
		},
		"./runtime": {
			"types": "./dist/runtime/index.d.ts",
			"import": "./dist/runtime/index.js"
		},
		"./react": {
			"types": "./dist/react/index.d.ts",
			"import": "./dist/react/index.js"
		},
		"./vite": {
			"types": "./dist/plugin/vite.d.ts",
			"import": "./dist/plugin/vite.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@typescript/native-preview": "^7.0.0-dev.20260203.1",
		"bundle-require": "^5.1.0",
		"esbuild": "^0.25.0",
		"glob": "^11.0.0",
		"oxc-parser": "^0.60.0",
		"vite": "^6.0.0"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"tsup": "^8.0.0",
		"typescript": "^5.7.0"
	},
	"peerDependencies": {
		"react": ">=18.0.0",
		"react-dom": ">=18.0.0"
	}
}
