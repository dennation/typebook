{
	"name": "@dennation/menu",
	"version": "0.1.0",
	"description": "Router-agnostic navigation menu model, React renderer, and TanStack Router adapter",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs"
		},
		"./react": {
			"types": "./dist/react/index.d.ts",
			"import": "./dist/react/index.mjs"
		},
		"./tanstack-router": {
			"types": "./dist/tanstack-router/index.d.ts",
			"import": "./dist/tanstack-router/index.mjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "vite build",
		"dev": "vite build --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run"
	},
	"devDependencies": {
		"@tanstack/react-router": "^1.170.4",
		"@tanstack/router-core": "1.171.2",
		"@types/node": "^22.0.0",
		"@types/react": "^19.0.0",
		"react": "^19.0.0",
		"vite": "^6.0.0",
		"vite-plugin-dts": "^4.5.0",
		"vitest": "^4.0.18"
	},
	"peerDependencies": {
		"@tanstack/react-router": ">=1.168.0",
		"react": ">=18.0.0",
		"typescript": ">=5.0.0"
	},
	"peerDependenciesMeta": {
		"@tanstack/react-router": {
			"optional": true
		},
		"typescript": {
			"optional": true
		}
	}
}
